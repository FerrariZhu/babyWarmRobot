generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles                 UserRole[]
  lessonsCreated        Lesson[]              @relation("LessonCreatedBy")
  lessonsTeaching       Lesson[]              @relation("LessonTeacher")
  dayPermissions        UserDayPermission[]
  baseDayAssignments    DayTeacherAssignment[] @relation("BaseTeacher")
  substituteAssignments DayTeacherAssignment[] @relation("SubstituteTeacher")
  assignmentsMade       DayTeacherAssignment[] @relation("AssignedBy")

  @@map("users")
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model DayTeacherAssignment {
  dayIndex              Int      @id @map("day_index")
  baseTeacherId         String   @map("base_teacher_id")
  substituteTeacherId   String?  @map("substitute_teacher_id")
  assignedByUserId      String?  @map("assigned_by_user_id")
  assignedAt            DateTime? @map("assigned_at")

  baseTeacher       User  @relation("BaseTeacher", fields: [baseTeacherId], references: [id], onDelete: Restrict)
  substituteTeacher User? @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id], onDelete: SetNull)
  assignedBy        User? @relation("AssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@map("day_teacher_assignments")
}

model UserDayPermission {
  id              String  @id @default(uuid())
  userId          String  @map("user_id")
  dayIndex        Int     @map("day_index")
  canCreate       Boolean @default(true) @map("can_create")
  canEdit         Boolean @default(true) @map("can_edit")
  canDeleteOthers Boolean @default(true) @map("can_delete_others")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayIndex])
  @@map("user_day_permissions")
}

model Lesson {
  id              String    @id @default(uuid())
  dayIndex        Int       @map("day_index")
  order           Int       @default(0)
  title           String
  goal            String?
  date            DateTime?
  block           String?
  teacherId       String?   @map("teacher_id")
  createdByUserId String?   @map("created_by_user_id")
  ageGroup        String?   @map("age_group")
  status          String    @default("planned")
  isDraft         Boolean   @default(false) @map("is_draft")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  teacher   User? @relation("LessonTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  createdBy User? @relation("LessonCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([dayIndex, order])
  @@map("lessons")
}
