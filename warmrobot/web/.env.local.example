# ══════════════════════════════════════════════════════════════
# 云服务（硅基流动 SiliconFlow）— 无需本地 Ollama / SAM / rembg
# https://siliconflow.cn
# ══════════════════════════════════════════════════════════════

# ── 视觉识别（衣柜拍照 / 商品截图）────────────────────────────
VISION_PROVIDER=openai_compat
VISION_API_KEY=sk-...
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
VISION_TIMEOUT_MS=120000
# VISION_IMAGE_MAX_EDGE=1280

# ── 衣物预览图（扫描时裁剪 + 白底卡片，无本地模型）────────────
GARMENT_IMAGE_SIZE=800
GARMENT_CROP_PADDING=0.02

# ── 入库前云美化（有 VISION_API_KEY 时 auto 开启；拍照上传时即生成白底商品图）──
BEAUTIFY_ENABLED=auto
# BEAUTIFY_API_KEY=sk-...   # 或复用 VISION_API_KEY
# BEAUTIFY_BASE_URL=https://api.siliconflow.cn/v1
BEAUTIFY_MODEL=Qwen/Qwen-Image-Edit-2509
# BEAUTIFY_GUIDANCE_SCALE=2.5   # 越低越贴近原图，默认 2.5
# 提示词默认在代码内；已内置白衣服/白背景同色保护（LOW-CONTRAST / SAME-COLOR PROTECTION）
# BEAUTIFY_NEGATIVE_PROMPT=short sleeves, cropped sleeves, altered sleeve length, redesigned garment

# ── 商品库相似匹配 Embedding（可选，复用 VISION_API_KEY）──────
# EMBEDDING_PROVIDER=openai_compat
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_DB_DIMENSIONS=1536

# 其他第三方详情 API（可选，URL 中可用 {itemId}）
# TAOBAO_PARSE_API_URL=https://your-parser.example.com/item?id={itemId}
# TAOBAO_PARSE_API_KEY=
